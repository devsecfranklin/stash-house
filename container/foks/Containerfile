FROM golang:1.26-alpine AS builder

RUN apk add --no-cache gcc musl-dev libpcsclite-dev pkgconfig
WORKDIR /app
COPY . .
RUN go build -o foks-server ./cmd/server

FROM alpine:latest
RUN apk add --no-cache pcscd libpcsclite
COPY --from=builder /app/foks-server /usr/local/bin/foks-server
ENTRYPOINT ["foks-server"]
